<!DOCTYPE html>
<html lang="ja">
  <head>
    <title>メッセージボード</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag 'application', media: 'all' %>
    <%= stylesheet_link_tag "trix" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-gradient-to-br from-indigo-50 via-purple-50 to-pink-50 min-h-screen">
    <header class="bg-gradient-to-r from-indigo-600 via-purple-600 to-pink-500 shadow-lg">
      <div class="max-w-4xl mx-auto px-6 py-4 flex items-center justify-between">
        <h1 class="text-2xl font-bold text-white tracking-wide">
          ✉️ メッセージボード
        </h1>
        <%= link_to "一覧へ戻る", messages_path, class: "text-white/80 hover:text-white text-sm underline" %>
      </div>
    </header>

    <% if notice.present? %>
      <div class="max-w-4xl mx-auto px-6 mt-4">
        <div class="bg-green-100 border border-green-400 text-green-800 px-4 py-3 rounded-lg">
          <%= notice %>
        </div>
      </div>
    <% end %>

    <main class="max-w-4xl mx-auto px-6 py-8">
      <%= yield %>
    </main>
  </body>
</html>
