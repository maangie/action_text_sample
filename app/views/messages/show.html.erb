<div class="bg-white rounded-2xl shadow-md border border-purple-100 p-8 mb-6">
  <h2 class="text-2xl font-bold text-purple-700 mb-4">💬 メッセージ詳細</h2>
  <div class="prose max-w-none text-gray-700 border-l-4 border-purple-300 pl-4">
    <%= @message.content %>
  </div>
</div>

<div class="flex gap-3">
  <%= link_to "✏️ 編集", edit_message_path(@message), class: "bg-gradient-to-r from-purple-500 to-pink-500 hover:from-purple-600 hover:to-pink-600 text-white font-semibold px-5 py-2 rounded-full shadow transition" %>
  <%= link_to "← 一覧へ", messages_path, class: "bg-white hover:bg-gray-50 text-gray-600 border border-gray-300 font-semibold px-5 py-2 rounded-full shadow transition" %>
</div>
