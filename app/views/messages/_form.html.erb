<%= form_with(model: message) do |form| %>
  <% if message.errors.any? %>
    <div class="bg-red-50 border border-red-300 text-red-700 rounded-xl p-4 mb-4">
      <p class="font-semibold mb-1">⚠️ <%= message.errors.count %>件のエラーがあります：</p>
      <ul class="list-disc list-inside text-sm">
        <% message.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="bg-white rounded-2xl shadow-md border border-indigo-100 p-6 mb-4">
    <%= form.label :content, "本文", class: "block text-sm font-semibold text-indigo-600 mb-2" %>
    <%= form.rich_text_area :content, class: "w-full min-h-40" %>
  </div>

  <div>
    <%= form.submit "保存する", class: "bg-gradient-to-r from-indigo-500 to-purple-500 hover:from-indigo-600 hover:to-purple-600 text-white font-semibold px-6 py-2 rounded-full shadow cursor-pointer transition" %>
  </div>
<% end %>
