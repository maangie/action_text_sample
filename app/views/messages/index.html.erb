<div class="flex items-center justify-between mb-8">
  <h2 class="text-3xl font-bold text-indigo-700">📋 メッセージ一覧</h2>
  <%= link_to "＋ 新規作成", new_message_path, class: "bg-gradient-to-r from-indigo-500 to-purple-500 hover:from-indigo-600 hover:to-purple-600 text-white font-semibold px-5 py-2 rounded-full shadow transition" %>
</div>

<% if @messages.empty? %>
  <div class="text-center py-16 text-gray-400">
    <p class="text-5xl mb-4">📭</p>
    <p class="text-lg">まだメッセージがありません</p>
  </div>
<% else %>
  <div class="grid gap-4">
    <% colors = ["from-indigo-100 to-purple-100 border-indigo-200", "from-purple-100 to-pink-100 border-purple-200", "from-pink-100 to-rose-100 border-pink-200", "from-teal-100 to-cyan-100 border-teal-200"] %>
    <% @messages.each_with_index do |message, i| %>
      <div class="bg-gradient-to-r <%= colors[i % colors.size] %> border rounded-2xl p-5 shadow-sm hover:shadow-md transition">
        <div class="text-gray-700 mb-3 line-clamp-2">
          <%= message.content %>
        </div>
        <div class="flex gap-3 text-sm">
          <%= link_to "👁 詳細", message, class: "bg-white hover:bg-indigo-50 text-indigo-600 border border-indigo-300 px-3 py-1 rounded-full transition" %>
          <%= link_to "✏️ 編集", edit_message_path(message), class: "bg-white hover:bg-purple-50 text-purple-600 border border-purple-300 px-3 py-1 rounded-full transition" %>
          <%= button_to "🗑 削除", message, method: :delete, class: "bg-white hover:bg-red-50 text-red-500 border border-red-300 px-3 py-1 rounded-full transition cursor-pointer" %>
        </div>
      </div>
    <% end %>
  </div>
<% end %>
